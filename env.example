# ── Apify (get from apify.com → Settings → Integrations) ─────────────────────
APIFY_TOKEN=your-service-role-key-here

# ── Supabase (get from supabase.com → Project Settings → API) ────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Competitor LinkedIn URLs ──────────────────────────────────────────────────
HEFT_LINKEDIN_URL=https://www.linkedin.com/company/heft-heavy-equipment/
AMRIK_LINKEDIN_URL=https://www.linkedin.com/company/amrik-singh-and-sons/
BARKAT_LINKEDIN_URL=https://www.linkedin.com/company/barkat-cranes/

# ── Optional: protect manual /api/poll trigger ────────────────────────────────
POLL_SECRET=choose-any-random-string

# ── Optional: restrict CORS to your Netlify URL ───────────────────────────────
FRONTEND_URL=https://your-site.netlify.app
